{
  "name": "just-talk",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && node --watch src/index.js",
    "install:all": "cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "multer": "^1.4.4-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
